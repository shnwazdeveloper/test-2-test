# ── Telegram ──────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ── MongoDB ────────────────────────────────────────────────────────
# MongoDB Atlas connection string (recommended for Render deployment)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/stickerbot?retryWrites=true&w=majority

# ── Server ─────────────────────────────────────────────────────────
# Port for the Express health-check server
# Render sets this automatically in production — only needed for local dev
PORT=3000

# ── Environment ────────────────────────────────────────────────────
NODE_ENV=development
